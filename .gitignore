# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Local databases
*.db
*.sqlite
*.sqlite3

# Logs and generated reports
data/logs/*
!data/logs/.gitkeep

# Evidence and collected machine data
data/evidence/*
!data/evidence/.gitkeep

data/evidence_packages/*
!data/evidence_packages/.gitkeep

# Self-healing generated files
data/self_healing/backups/*
!data/self_healing/backups/.gitkeep

data/self_healing/patches/*
!data/self_healing/patches/.gitkeep

data/self_healing/screenshots/*
!data/self_healing/screenshots/.gitkeep

# OS/editor files
.DS_Store
Thumbs.db
.vscode/